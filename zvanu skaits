# Zvanu skaita prognozes izveide

fit_zvani <- auto.arima(ts_zvanu_skaits_diena, seasonal = TRUE)
fc_zvani <- forecast(fit_zvani, h = 14)

fc_plot_zvani <- autoplot(fc_zvani) +
  
  ggtitle("Zvani dienā - prognoze ar 95% un 80% ticamības intervāliem") +
  scale_x_continuous( breaks = scales::pretty_breaks(n = 7), 
                      labels = function(x) paste0(x, ". nedēļa")) + 
  xlab("Nedēļa pēc kārtas") +
  ylab("Zvanu skaits") +
  theme_bw()

fc_plot_zvani 
