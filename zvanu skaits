# ggsave("fc_plot_zvani .png", plot = fc_plot_zvani , width = 8, height = 6, dpi = 300)


checkresiduals(fc_zvani)

# Ljung-Box test
# 
# data:  Residuals from ARIMA(1,0,1)(1,1,0)[7] with drift
# Q* = 2.5064, df = 3, p-value = 0.4741
# 
# Model df: 3.   Total lags used: 6

# Tā kā pēc Lung-box testa p-vērtība ir lielāka 
# par 0.05, tad modelī nav saglabājusies autokorelācija, kas ir labi un prognozei būtu jābūt ticamai.



dienu_sezonalitate <-
