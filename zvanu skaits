aktivo_saraksts <- function(Diena) {
  pakalpojumi %>%
    filter(Pakalpojums == 2,
           Pak_piesl_datums <= Diena,
           Pak_atsl_datums >= Diena)
}

zvanu_tabula <- notikumi_t %>%
  filter(notikums == "zvani")

zvanu_skaits_diena <- do.call(rbind, lapply(1:30, function(d) {
  aktivi <- aktivo_saraksts(d)
  
  zvani_diena <- zvanu_tabula %>%
    filter(datums == d) %>%
    inner_join(aktivi, by = c("lietotajs" = "Lietotaja_ID"))
  data.frame(diena = d,
             Zvanu_skaits = sum(zvani_diena$skaits))
}))

